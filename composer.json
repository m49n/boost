{
    "name": "october/boost",
    "description": "October CMS Boost provides AI agents with the essential context, guidelines, skills, and tools needed to write high-quality October CMS code.",
    "keywords": [
        "dev",
        "octobercms",
        "ai",
        "boost"
    ],
    "homepage": "https://github.com/octobercms/boost",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/octobercms/boost/issues",
        "source": "https://github.com/octobercms/boost"
    },
    "require": {
        "php": "^8.1",
        "laravel/boost": "^1.0|^2.0"
    },
    "autoload": {
        "psr-4": {
            "October\\Boost\\": "src/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "1.x-dev"
        },
        "laravel": {
            "providers": [
                "October\\Boost\\ServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}